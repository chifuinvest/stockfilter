# ============================================================
#  AI 产业链全市场量化监控系统 · 环境变量模板
#  使用方式：
#    1) 复制本文件为 .env（.gitignore 已忽略 .env，不会提交）
#    2) 填真实值后保存
#    3) 或直接把下面的变量 export 到 shell / systemd / Docker
# ============================================================

# ---------- Tushare Token（必填，否则 A股/港股无法走 Tushare 数据源）
# 注册地址：https://tushare.pro/register
# 免费账户可用额度：港股 hk_daily 1次/分钟 + 5次/天；A股 daily 200次/分钟
# 说明：优先从 ~/.tushare/token.txt 读取；环境变量的优先级更高
TUSHARE_TOKEN=请填写你的真实TushareToken

# ---------- Flask 监听配置（可选，默认值如下）
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
FLASK_ENV=production

# ---------- 本地路径（可选，默认在项目 data_cache/ 下；
#            部署到服务器时建议改到绝对路径避免权限问题）
# DATA_CACHE_DIR=/var/lib/stockfilter/data_cache
# YF_CACHE_DIR=/var/cache/stockfilter/yfinance
